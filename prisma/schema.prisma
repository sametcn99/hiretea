generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  RECRUITER
  CANDIDATE
}

enum CandidateCaseStatus {
  DRAFT
  PROVISIONING
  READY
  IN_PROGRESS
  REVIEWING
  COMPLETED
  ARCHIVED
}

enum CandidateCaseDecision {
  ADVANCE
  HOLD
  REJECT
}

enum CandidateInviteIssueKind {
  INITIAL
  RESEND
}

enum RecruiterInviteIssueKind {
  INITIAL
  RESEND
}

enum CaseTemplateRepositorySourceKind {
  PROVISIONED
  LINKED_EXISTING
  COPIED_FROM_EXISTING
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  emailVerified DateTime?
  image         String?
  role          UserRole        @default(CANDIDATE)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  accounts      Account[]
  sessions      Session[]
  giteaIdentity GiteaIdentity?
  caseTemplates CaseTemplate[]  @relation("CaseTemplateCreator")
  candidateCases CandidateCase[] @relation("CandidateAssignments")
  createdCases  CandidateCase[] @relation("CaseAssignmentCreator")
  candidateInvites CandidateInvite[] @relation("CandidateInviteRecipient")
  createdCandidateInvites CandidateInvite[] @relation("CandidateInviteCreator")
  recruiterInvites RecruiterInvite[] @relation("RecruiterInviteRecipient")
  createdRecruiterInvites RecruiterInvite[] @relation("RecruiterInviteCreator")
  assignedCaseTemplateReviews CaseTemplateReviewerAssignment[] @relation("CaseTemplateReviewer")
  createdCaseTemplateReviewerAssignments CaseTemplateReviewerAssignment[] @relation("CaseTemplateReviewerAssignmentCreator")
  assignedCandidateCaseReviews CandidateCaseReviewerAssignment[] @relation("CandidateCaseReviewer")
  createdCandidateCaseReviewerAssignments CandidateCaseReviewerAssignment[] @relation("CandidateCaseReviewerAssignmentCreator")
  evaluations   EvaluationNote[] @relation("EvaluationAuthor")
  auditLogs     AuditLog[]      @relation("AuditActor")
}

model GiteaIdentity {
  id              String   @id @default(cuid())
  userId          String   @unique
  giteaUserId     Int      @unique
  login           String   @unique
  email           String?
  avatarUrl       String?
  profileUrl      String?
  initialPassword String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkspaceSettings {
  id                   String   @id @default(cuid())
  companyName          String
  defaultBranch        String   @default("main")
  manualInviteMode     Boolean  @default(true)
  giteaBaseUrl         String
  giteaAdminBaseUrl    String?
  giteaOrganization    String
  giteaAuthClientId    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model CaseTemplate {
  id                    String          @id @default(cuid())
  slug                  String          @unique
  name                  String
  summary               String
  repositoryOwner       String
  repositoryName        String
  repositoryDescription String?
  repositorySourceKind  CaseTemplateRepositorySourceKind @default(PROVISIONED)
  sourceRepositoryOwner String?
  sourceRepositoryName  String?
  defaultBranch         String          @default("main")
  createdById           String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  createdBy             User            @relation("CaseTemplateCreator", fields: [createdById], references: [id], onDelete: Restrict)
  candidateCases        CandidateCase[]
  reviewerAssignments   CaseTemplateReviewerAssignment[]
  reviewGuide           CaseTemplateReviewGuide?

  @@unique([repositoryOwner, repositoryName])
}

model CaseTemplateReviewerAssignment {
  id             String       @id @default(cuid())
  caseTemplateId String
  reviewerId     String
  assignedById   String?
  createdAt      DateTime     @default(now())
  caseTemplate   CaseTemplate @relation(fields: [caseTemplateId], references: [id], onDelete: Cascade)
  reviewer       User         @relation("CaseTemplateReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  assignedBy     User?        @relation("CaseTemplateReviewerAssignmentCreator", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([caseTemplateId, reviewerId])
  @@index([reviewerId, createdAt])
}

model CaseTemplateReviewGuide {
  id                   String                       @id @default(cuid())
  caseTemplateId       String                       @unique
  reviewerInstructions String?
  decisionGuidance     String?
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt
  caseTemplate         CaseTemplate                 @relation(fields: [caseTemplateId], references: [id], onDelete: Cascade)
  rubricCriteria       CaseTemplateRubricCriterion[]
}

model CaseTemplateRubricCriterion {
  id           String                  @id @default(cuid())
  reviewGuideId String
  title        String
  description  String?
  weight       Int?
  sortOrder    Int                     @default(0)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  reviewGuide  CaseTemplateReviewGuide @relation(fields: [reviewGuideId], references: [id], onDelete: Cascade)

  @@index([reviewGuideId, sortOrder])
}

model CandidateCase {
  id                  String              @id @default(cuid())
  caseTemplateId      String
  candidateId         String
  createdById         String
  status              CandidateCaseStatus @default(DRAFT)
  decision            CandidateCaseDecision?
  workingRepository   String?
  branchName          String?
  workingRepositoryUrl String?
  dueAt               DateTime?
  startedAt           DateTime?
  submittedAt         DateTime?
  reviewedAt          DateTime?
  lastSyncedAt        DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  caseTemplate        CaseTemplate        @relation(fields: [caseTemplateId], references: [id], onDelete: Restrict)
  candidate           User                @relation("CandidateAssignments", fields: [candidateId], references: [id], onDelete: Restrict)
  createdBy           User                @relation("CaseAssignmentCreator", fields: [createdById], references: [id], onDelete: Restrict)
  accessGrants        CandidateAccessGrant[]
  reviewerAssignments CandidateCaseReviewerAssignment[]
  evaluationNotes     EvaluationNote[]
}

model CandidateCaseReviewerAssignment {
  id              String        @id @default(cuid())
  candidateCaseId String
  reviewerId      String
  assignedById    String?
  createdAt       DateTime      @default(now())
  candidateCase   CandidateCase @relation(fields: [candidateCaseId], references: [id], onDelete: Cascade)
  reviewer        User          @relation("CandidateCaseReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  assignedBy      User?         @relation("CandidateCaseReviewerAssignmentCreator", fields: [assignedById], references: [id], onDelete: SetNull)

  @@unique([candidateCaseId, reviewerId])
  @@index([reviewerId, createdAt])
}

model CandidateAccessGrant {
  id                 String        @id @default(cuid())
  candidateCaseId    String
  repositoryName     String
  permissionKey      String
  canRead            Boolean       @default(true)
  canWrite           Boolean       @default(false)
  canOpenIssues      Boolean       @default(false)
  canOpenPullRequests Boolean      @default(false)
  grantedAt          DateTime      @default(now())
  revokedAt          DateTime?
  candidateCase      CandidateCase @relation(fields: [candidateCaseId], references: [id], onDelete: Cascade)
}

model CandidateInvite {
  id              String                   @id @default(cuid())
  candidateId     String
  createdById     String?
  previousInviteId String?
  issueKind       CandidateInviteIssueKind @default(INITIAL)
  resendSequence  Int                      @default(1)
  tokenHash       String                   @unique
  expiresAt       DateTime
  claimedAt       DateTime?
  revokedAt       DateTime?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  candidate       User                     @relation("CandidateInviteRecipient", fields: [candidateId], references: [id], onDelete: Cascade)
  createdBy       User?                    @relation("CandidateInviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  previousInvite  CandidateInvite?         @relation("CandidateInviteChain", fields: [previousInviteId], references: [id], onDelete: SetNull)
  resentInvites   CandidateInvite[]        @relation("CandidateInviteChain")

  @@index([candidateId, createdAt])
  @@index([candidateId, resendSequence])
  @@unique([candidateId, resendSequence])
}

model RecruiterInvite {
  id               String                   @id @default(cuid())
  recruiterId      String
  createdById      String?
  previousInviteId String?
  issueKind        RecruiterInviteIssueKind @default(INITIAL)
  resendSequence   Int                      @default(1)
  tokenHash        String                   @unique
  expiresAt        DateTime
  claimedAt        DateTime?
  revokedAt        DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  recruiter        User                     @relation("RecruiterInviteRecipient", fields: [recruiterId], references: [id], onDelete: Cascade)
  createdBy        User?                    @relation("RecruiterInviteCreator", fields: [createdById], references: [id], onDelete: SetNull)
  previousInvite   RecruiterInvite?         @relation("RecruiterInviteChain", fields: [previousInviteId], references: [id], onDelete: SetNull)
  resentInvites    RecruiterInvite[]        @relation("RecruiterInviteChain")

  @@index([recruiterId, createdAt])
  @@index([recruiterId, resendSequence])
  @@unique([recruiterId, resendSequence])
}

model EvaluationNote {
  id              String        @id @default(cuid())
  candidateCaseId String
  authorId        String
  score           Int?
  summary         String
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  candidateCase   CandidateCase @relation(fields: [candidateCaseId], references: [id], onDelete: Cascade)
  author          User          @relation("EvaluationAuthor", fields: [authorId], references: [id], onDelete: Restrict)
}

model AuditLog {
  id           String   @id @default(cuid())
  actorId      String?
  action       String
  resourceType String
  resourceId   String?
  detail       Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  actor        User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
}

model WebhookDelivery {
  id             String   @id @default(cuid())
  deliveryId     String?  @unique
  eventName      String
  payload        Json
  statusCode     Int?
  errorMessage   String?
  processedAt    DateTime?
  createdAt      DateTime @default(now())
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}