{
  "name": "hiretea",
  "displayName": "Hiretea",
  "version": "0.1.0",
  "private": true,
  "author": {
    "email": "contact@sametcc.me",
    "name": "sametcn99",
    "url": "https://sametcc.me"
  },
  "license": "GPL-3.0-only",
  "repository": {
    "url": "https://github.com/sametcn99/hiretea"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "smoke:test": "bash ./tests/smoke-test.sh",
    "test:unit": "vitest run --config vitest.config.ts",
    "test:integration": "bash ./tests/integration-test.sh",
    "test:smoke": "bun run smoke:test",
    "test:ci": "bun run lint:ci && bun run typecheck && bun run test:unit && bun run test:integration",
    "docker:auto-bootstrap": "bun run docker/scripts/bootstrap-app.ts",
    "docker:wait": "bun run docker/scripts/wait-for-stack.ts",
    "docker:up": "docker compose -p hiretea -f docker-compose.yml up --build -d && bun run docker:wait",
    "docker:watch": "HIRETEA_APP_BUILD_TARGET=development HIRETEA_APP_MODE=dev docker compose -p hiretea -f docker-compose.yml up --build --watch",
    "lint": "biome lint --write --unsafe",
    "lint:ci": "biome lint .",
    "check": "biome check --write --unsafe && bun run typecheck",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "next": "16.2.4",
    "next-auth": "^4.24.14",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "prisma": "^7.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
