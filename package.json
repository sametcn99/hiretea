{
  "name": "hiretea",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "smoke:test": "./scripts/smoke-test.sh",
    "docker:auto-bootstrap": "bun run scripts/docker/bootstrap-app.ts",
    "docker:down": "docker compose down --volumes --remove-orphans",
    "docker:nuke": "docker compose down --volumes --remove-orphans --rmi all",
    "docker:up": "docker compose up --build -d",
    "docker:watch": "HIRETEA_APP_BUILD_TARGET=development HIRETEA_APP_MODE=dev docker compose up --build --watch",
    "lint": "biome lint --write --unsafe",
    "check": "biome check --write --unsafe && bun run typecheck",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/themes": "^3.3.0",
    "next": "16.2.3",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "babel-plugin-react-compiler": "1.0.0",
    "prisma": "^7.7.0",
    "typescript": "^6.0.2"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
